APP_ENV=local
APP_NAME=HY-chat
APP_PORT=8000
LOG_LEVEL=INFO

# 浏览器访问的 LangGraph Agent Server 地址
AGENT_PUBLIC_URL=/api
BACKEND_PUBLIC_URL=http://localhost:8000

# Docker Compose 内部服务名：postgres / redis
DATABASE_URL=postgresql+psycopg://hy_chat:hy_chat_password@postgres:5432/hy_chat_db
REDIS_URL=redis://redis:6379/0

# 身份认证：生产环境务必替换为高强度随机值
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_MINUTES=30
JWT_REFRESH_TOKEN_DAYS=30
# 生产环境必填；只有该邮箱能在尚无管理员时完成管理员初始化
INITIAL_ADMIN_EMAIL=admin@example.com

# 密码找回：生产环境建议配置 SMTP，由系统发送一次性重置链接。
PASSWORD_RESET_TOKEN_MINUTES=30
PASSWORD_RESET_BASE_URL=http://localhost:3000
# 仅本地开发调试可设为 true；生产环境会强制忽略，不会返回明文重置 token。
PASSWORD_RESET_EXPOSE_TOKEN=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT=10

# 新注册普通用户的默认 AI 权限（本地未配置 INITIAL_ADMIN_EMAIL 时仍由首个账号成为管理员）
DEFAULT_RPM_LIMIT=30
DEFAULT_MONTHLY_TOKEN_QUOTA=1000000
DEFAULT_ALLOW_HIGH_COST_TOOLS=false
DEFAULT_ALLOW_IMAGE_GENERATION=true

# 人工审批：图片生成、联网搜索和股票查询在执行前暂停，等待批准/编辑/拒绝
HITL_ENABLED=true

# 智谱：不填也能启动，但会使用 mock 模型输出
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_CHAT_MODEL=glm-5.2
# 模型按推荐顺序配置：5.2 作为旗舰默认；5.1 与 5-Turbo 作为 5 系列备选。
ZHIPU_CHAT_MODELS=glm-5.2,glm-5.1,glm-5-turbo
ZHIPU_IMAGE_MODEL=glm-image
ZHIPU_EMBEDDING_MODEL=embedding-3
EMBEDDING_DIMENSIONS=1024

# 工具调用：联网搜索与股票行情需要各自的 API Key；天气工具无需 Key
TAVILY_API_KEY=
ALPHA_VANTAGE_API_KEY=
EXTERNAL_API_TIMEOUT=20
IMAGE_API_TIMEOUT=120

# Redis Cache
CACHE_ENABLED=true
CACHE_DEFAULT_TTL=600
CHAT_RESPONSE_CACHE_TTL=600
CACHE_EMBEDDING_TTL=604800
CACHE_NEGATIVE_TTL=60
CACHE_TTL_JITTER_RATIO=0.1
CACHE_LOCK_TTL=30
CACHE_LOCK_WAIT_SECONDS=3
CACHE_LOCK_POLL_SECONDS=0.05

# RAG
RAG_UPLOAD_DIR=/data/rag/uploads
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=150
RAG_TOP_K=4

# 文件对象存储。local 可直接启动；s3 支持 AWS S3、MinIO、R2 等兼容服务
STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=/data/storage
MAX_UPLOAD_BYTES=52428800
S3_ENDPOINT_URL=
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
S3_PRESIGN_EXPIRY_SECONDS=900

# LangSmith：不填也能启动；填了之后可在 LangSmith 平台看到 trace
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=hy-chat
# 如果你的账号不是默认区域，再打开下面这行
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Coding Agent 工作区，只允许读写这个目录下面的文件
WORKSPACE_ROOT=/workspace

# 命令执行安全开关：默认 false。学习阶段建议先不开。
ENABLE_COMMAND_TOOL=false

# Coding Agent 运行状态与列表
AGENT_RUN_STATUS_TTL_SECONDS=3600
AGENT_RUN_LIST_LIMIT=20

# Web UI
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
