    <mxCell id="lane-browser" value="浏览器 / React" style="swimlane;horizontal=0;startSize=130;fillColor=#EAF2FF;strokeColor=#4C78C2;fontSize=16;fontStyle=1;html=1;" vertex="1" parent="1">
      <mxGeometry x="20" y="60" width="1720" height="190" as="geometry"/>
