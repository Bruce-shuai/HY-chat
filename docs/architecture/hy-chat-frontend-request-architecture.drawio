    <mxCell id="lg-sdk" value="&lt;b&gt;LangGraph SDK&lt;/b&gt;&lt;br&gt;useStream()&lt;br&gt;Client.threads.search()&lt;br&gt;请求基址：NEXT_PUBLIC_API_URL" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=12;fillColor=#FFFFFF;strokeColor=#4C78C2;fontSize=14;" vertex="1" parent="lane-browser">
      <mxGeometry x="810" y="35" width="270" height="130" as="geometry"/>
    </mxCell>
    <mxCell id="rest-client" value="&lt;b&gt;业务 REST 请求&lt;/b&gt;&lt;br&gt;fetch / authFetch&lt;br&gt;Authorization: Bearer JWT&lt;br&gt;基址：NEXT_PUBLIC_BACKEND_URL" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=12;fillColor=#FFFFFF;strokeColor=#4C78C2;fontSize=14;" vertex="1" parent="lane-browser">
