    <mxCell id="pages" value="&lt;b&gt;页面路由&lt;/b&gt;&lt;br&gt;/  聊天&lt;br&gt;/images  图片&lt;br&gt;/files  文件&lt;br&gt;/traces  追踪&lt;br&gt;/admin  管理" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=12;fillColor=#FFFFFF;strokeColor=#4C78C2;fontSize=14;" vertex="1" parent="lane-browser">
